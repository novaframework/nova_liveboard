{application, nova_liveboard, [
    {description, "Real-time BEAM VM dashboard for Nova"},
    {vsn, git},
    {registered, []},
    {mod, {nova_liveboard_app, []}},
    {applications, [
        kernel,
        stdlib,
        nova,
        arizona_core,
        arizona_nova
    ]},
    {env, [
        {nova_apps, [arizona_nova]}
    ]},
    {modules, []},
    {licenses, ["Apache-2.0"]}
]}.
